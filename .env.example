# Copy to .env and fill in to use the REAL Meta Marketing API.
# Leave META_MODE=mock to run the full launch loop with fake IDs (no credentials needed).

META_MODE=mock                 # mock | live
META_API_VERSION=v21.0
META_APP_ID=
META_APP_SECRET=

# Per-client values you obtain via Facebook Login OAuth (one set per connected client).
# In mock mode these are ignored.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=            # e.g. act_1234567890
META_PAGE_ID=

# Lead webhook (Meta -> your app) verification token, and where leads get forwarded.
META_VERIFY_TOKEN=demo_verify
CLIENT_CRM_WEBHOOK=

PORT=3000
